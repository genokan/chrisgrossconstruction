# Security headers applied by Cloudflare Pages to every response.
# CSP notes: fonts are self-hosted by next/font, images are local, the only
# third-party embed is the Google Maps iframe on the contact page.
# 'unsafe-inline' for script/style is required by Next.js static export
# (no nonce support without a server); can be tightened later via a Worker.
/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), camera=(), microphone=(), payment=(), usb=(), interest-cohort=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains
  Content-Security-Policy: default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'none'; form-action 'self'; img-src 'self' data:; font-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'; connect-src 'self'; frame-src https://www.google.com https://maps.google.com; upgrade-insecure-requests
